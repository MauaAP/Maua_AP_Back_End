datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String            @id @default(uuid())
  name        String
  email       String            @unique
  role        String
  password    String
  telefone    String            @unique
  cpf         String            @unique
  status      String
  presences   Presence[]
  evaluations EventEvaluation[]
}

model Event {
  id                    String             @id @default(uuid())
  eventName             String
  date                  DateTime
  host                  String
  manager               String[]
  hostEmail             String[]
  hostPhone             String[]
  local                 String
  modality              String
  targetAudience        String
  activityType          String
  maxParticipants       Int?
  goals                 String
  period                String
  contentActivities     String[]
  developedCompetencies String
  initTime              DateTime
  finishTime            DateTime
  link                  String?
  presences             Presence[]
  ExternalPresence      ExternalPresence[]
  evaluations           EventEvaluation[]
}

model Presence {
  id      String   @id @default(uuid())
  eventId String
  event   Event    @relation(fields: [eventId], references: [id])
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  date    DateTime

  @@unique([eventId, userId])
}

model ExternalPresence {
  id      String   @id @default(uuid())
  eventId String
  event   Event    @relation(fields: [eventId], references: [id])
  name    String
  email   String
  date    DateTime
}

model EvaluationQuestion {
  id       String             @id @default(uuid())
  text     String
  type     String
  isActive Boolean            @default(true)
  answers  EvaluationAnswer[]
}

model EventEvaluation {
  id            String             @id @default(uuid())
  eventId       String
  event         Event              @relation(fields: [eventId], references: [id])
  userId        String?
  user          User?              @relation(fields: [userId], references: [id])
  externalEmail String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  answers       EvaluationAnswer[]

  @@unique([eventId, userId])
  @@unique([eventId, externalEmail])
}

model EvaluationAnswer {
  id           String             @id @default(uuid())
  evaluationId String
  evaluation   EventEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  questionId   String
  question     EvaluationQuestion @relation(fields: [questionId], references: [id])
  rating       Int?
  textAnswer   String?

  @@unique([evaluationId, questionId])
}
